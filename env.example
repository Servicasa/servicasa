# ServiCasa Environment Variables
# Copy this to .env and fill in your values

PORT=3000
JWT_SECRET=change-this-to-a-random-secret-string-in-production

# When you move to Supabase (free tier):
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Twilio (for WhatsApp/SMS notifications) - optional
# TWILIO_ACCOUNT_SID=ACxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxx
# TWILIO_PHONE=+1xxxxxxxx

# Mercado Pago (Colombia payments) - when ready for real payments
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxx
